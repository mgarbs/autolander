{
  "name": "@autolander/desktop",
  "version": "1.11.8",
  "private": true,
  "description": "AutoLander Desktop — Electron app with React UI + FB automation",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "npx vite --config src/renderer/vite.config.js src/renderer",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "build:renderer": "npx vite build --config src/renderer/vite.config.js src/renderer",
    "build": "npm run build:renderer && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "puppeteer-core": "^21.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "cheerio": "^1.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.3",
    "wait-on": "^7.2.0"
  }
}
